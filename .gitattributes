# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Python files
*.py text diff=python
*.pyi text diff=python
*.pyx text diff=python

# Documents
*.md text diff=markdown
*.txt text
*.csv text
*.json text
*.xml text
*.yaml text
*.yml text
*.toml text
*.cfg text
*.ini text

# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Graphics
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Archives
*.zip binary
*.gz binary
*.tar binary

# Python specific
*.pkl binary
*.pickle binary
*.pyc binary
*.pyd binary
*.so binary
*.egg-info binary
